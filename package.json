{
  "name": "frame-shift-video",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"vite\" \"FRAME_SHIFT_HOME=test-videos/ bun --watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "FRAME_SHIFT_HOME=test-videos/ bun --watch server/index.ts",
    "build": "bun run build:client && bun run build:server",
    "build:client": "vite build",
    "build:server": "bun build server/index.ts --target=bun --outfile=dist/server.js --format=esm",
    "preview": "vite preview",
    "start": "NODE_ENV=production bun run dist/server.js",
    "test": "bun test",
    "test:run": "bun test",
    "test:ui": "bun test --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@sentry/bun": "^10.63.0",
    "@sentry/react": "^10.63.0",
    "@sentry/vite-plugin": "^4.9.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-devtools": "^1.167.0",
    "date-fns": "^4.4.0",
    "lucide-react": "^0.546.0",
    "micromatch": "^4.0.8",
    "natural-orderby": "^5.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-error-boundary": "^6.1.2",
    "react-highlight-words": "^0.21.0",
    "react-virtuoso": "^4.18.10",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/router-plugin": "^1.168.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-highlight-words": "^0.20.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.3",
    "husky": "^9.1.7",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.3"
  }
}
